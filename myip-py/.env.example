# Optional provider keys. Never commit real secrets.
IPAPI_IS_KEY=
IPAPI_ORG_KEY=
IPINFO_TOKEN=
IPDATA_KEY=

MYIP_DEBUG=false
MYIP_CACHE_TTL_SECONDS=120
MYIP_RATE_LIMIT_PER_MINUTE=60

# Required before exposing /admin in production.
# Keep values private; do not use admin/change-me defaults.
MYIP_ADMIN_USERNAME=admin
MYIP_ADMIN_PASSWORD=
MYIP_ADMIN_SESSION_SECRET=
